# LLM Provider: openai | minimax-cn
LLM_PROVIDER=minimax-cn

# OpenAI settings
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# MiniMax China settings (Anthropic-compatible endpoint)
MINIMAX_CN_API_KEY=your-minimax-cn-api-key
MINIMAX_CN_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_CN_MODEL=MiniMax-M2.7

# Common LLM settings
TEMPERATURE=0.3

# Data directory
DATA_DIR=./data
